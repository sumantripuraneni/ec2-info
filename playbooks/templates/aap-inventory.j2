# AAP 2.4 Installer Inventory - Generated by Ansible
# This file is managed by deploy-aap.yml — do not edit manually on the host.
# AAP 2.4 supports single-node all-in-one deployment.

[automationcontroller]
{{ aap_fqdn }} ansible_connection=local

[automationhub]

[automationeda]

[database]

[all:vars]
admin_password='{{ aap_admin_password }}'

controller_hostname='{{ aap_fqdn }}'

pg_host='localhost'
pg_port=5432
pg_database='awx'
pg_username='awx'
pg_password='{{ aap_pg_password }}'
pg_sslmode='prefer'

registry_url='registry.redhat.io'
registry_username='{{ registry_username | default("") }}'
registry_password='{{ registry_password | default("") }}'
